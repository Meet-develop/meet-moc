# ──────────────────────────────────────────────────────────────
# meet-moc ローカル環境変数テンプレート
#
# このファイルをコピーして .env.local を作成してください:
#   cp .env.example .env.local
#
# .env.local は .gitignore により追跡されません（コミット不要）。
# ──────────────────────────────────────────────────────────────

# GitHub Personal Access Token
# 取得先: https://github.com/settings/tokens
# 必要なスコープ: repo (Issues・PR・ブランチの作成に必要)
# ※ Fine-grained token の場合: Contents(read/write), Issues(read/write), Pull requests(read/write)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_personal_access_token_here

# GitHub リポジトリ (チーム共通設定)
GITHUB_REPO=Meet-develop/meet-moc
