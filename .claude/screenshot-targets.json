{
  "$schema": "ci-screenshot",
  "_comment": "PR で変更されたファイル → 撮影対象URL のマッピング。`match` はminimatchパターン。複数マッチ可。`auth` は注入するシードユーザーID (nullなら未ログイン)。`label` はPRコメント上の見出し。",
  "seed": {
    "user1": "70000000-0000-0000-0000-000000000001",
    "user2": "70000000-0000-0000-0000-000000000002",
    "event1": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
    "event2": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb",
    "event3": "cccccccc-cccc-cccc-cccc-cccccccccccc"
  },
  "targets": [
    { "match": "app/page.tsx",                                 "label": "ホーム",                "url": "/",                                                      "auth": "user1" },
    { "match": "app/login/**",                                 "label": "ログイン",              "url": "/login",                                                 "auth": null },
    { "match": "app/signup/**",                                "label": "サインアップ",          "url": "/signup",                                                "auth": null },
    { "match": "app/setup/**",                                 "label": "セットアップ",          "url": "/setup",                                                 "auth": null },
    { "match": "app/onboarding/**",                            "label": "オンボーディング",       "url": "/onboarding",                                            "auth": "user1" },
    { "match": "app/events/new/**",                            "label": "イベント作成",          "url": "/events/new",                                            "auth": "user1" },
    { "match": "app/events/history/**",                        "label": "イベント履歴",          "url": "/events/history",                                        "auth": "user1" },
    { "match": "app/events/[id]/page.tsx",                     "label": "イベント詳細",          "url": "/events/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",          "auth": "user1" },
    { "match": "app/events/[id]/manage/**",                    "label": "イベント管理",          "url": "/events/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/manage",   "auth": "user1" },
    { "match": "app/profile/setup/**",                         "label": "プロフィール設定",      "url": "/profile/setup",                                         "auth": "user1" },
    { "match": "app/profile/[id]/**",                          "label": "プロフィール",          "url": "/profile/70000000-0000-0000-0000-000000000002",          "auth": "user1" },
    { "match": "app/friends/**",                               "label": "友達",                  "url": "/friends",                                               "auth": "user1" },
    { "match": "app/invitations/**",                           "label": "招待",                  "url": "/invitations",                                           "auth": "user1" },
    { "match": "app/notifications/page.tsx",                   "label": "通知一覧",              "url": "/notifications",                                         "auth": "user1" },
    { "match": "app/notifications/[id]/**",                    "label": "通知詳細",              "url": "/notifications",                                         "auth": "user1" },

    { "match": "components/features/events/event-card.tsx",        "label": "ホーム(イベントカード)",     "url": "/",                                                      "auth": "user1" },
    { "match": "components/features/events/date-scheduler.tsx",    "label": "イベント管理(日程)",         "url": "/events/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/manage",   "auth": "user1" },
    { "match": "components/features/events/participant-list.tsx",  "label": "イベント詳細(参加者)",       "url": "/events/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",          "auth": "user1" },
    { "match": "components/features/invitations/**",               "label": "招待カード",                 "url": "/invitations",                                           "auth": "user1" },
    { "match": "components/features/profile/**",                   "label": "プロフィール設定",           "url": "/profile/setup",                                         "auth": "user1" },
    { "match": "components/features/relationship/**",              "label": "プロフィール(リレーション)", "url": "/profile/70000000-0000-0000-0000-000000000002",          "auth": "user1" },
    { "match": "components/features/notes/**",                     "label": "イベント詳細(メモ)",         "url": "/events/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",          "auth": "user1" },
    { "match": "components/features/auth/**",                      "label": "ログイン",                   "url": "/login",                                                 "auth": null },
    { "match": "components/navigation/**",                         "label": "ホーム(ナビ)",               "url": "/",                                                      "auth": "user1" },
    { "match": "components/ui/**",                                 "label": "ホーム(UI)",                 "url": "/",                                                      "auth": "user1" },
    { "match": "components/pwa/**",                                "label": "ホーム(PWA)",                "url": "/",                                                      "auth": "user1" },
    { "match": "components/providers.tsx",                         "label": "ホーム",                     "url": "/",                                                      "auth": "user1" },

    { "match": "app/globals.css",                                  "label": "ホーム",                     "url": "/",                                                      "auth": "user1" },
    { "match": "app/layout.tsx",                                   "label": "ホーム",                     "url": "/",                                                      "auth": "user1" }
  ]
