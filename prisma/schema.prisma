generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RelationshipStatus {
  hot
  normal
  block

  @@map("relationship_status")
}

enum InvitationStatus {
  pending
  accepted
  declined
  maybe

  @@map("invitation_status")
}

enum ParticipantStatus {
  confirmed
  maybe
  declined

  @@map("participant_status")
}

model User {
  id             String           @id @default(uuid()) @db.Uuid
  username       String
  avatarUrl      String?          @map("avatar_url")
  createdAt      DateTime         @default(now()) @map("created_at")
  notes          Note[]
  events         Event[]          @relation("EventOrganizer")
  invitations    Invitation[]     @relation("InvitationInvitee")
  organizedInvites Invitation[]   @relation("InvitationOrganizer")
  eventParticipants EventParticipant[]
  dateOptionParticipants EventDateOptionParticipant[]
  userCategories UserCategory[]
  userAllergens  UserAllergen[]
  relationships  Relationship[]   @relation("RelationshipUser")
  relatedBy      Relationship[]   @relation("RelationshipTarget")

  @@map("users")
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  message   String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Event {
  id               String             @id @default(uuid()) @db.Uuid
  organizerId      String             @map("organizer_id") @db.Uuid
  title            String
  description      String?
  eventDate        DateTime?          @map("event_date") @db.Date
  location         String?
  priceCents       Int?               @map("price_cents")
  maxParticipants  Int?               @map("max_participants")
  imageUrl         String?            @map("image_url")
  createdAt        DateTime           @default(now()) @map("created_at")
  organizer        User               @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  hashtags         EventHashtag[]
  participants     EventParticipant[]
  dateOptions      EventDateOption[]
  invitations      Invitation[]

  @@map("events")
}

model EventHashtag {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @map("event_id") @db.Uuid
  tag     String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_hashtags")
}

model EventParticipant {
  eventId  String            @map("event_id") @db.Uuid
  userId   String            @map("user_id") @db.Uuid
  status   ParticipantStatus @default(confirmed)
  joinedAt DateTime          @default(now()) @map("joined_at")
  event    Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_participants")
}

model EventDateOption {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  optionDate DateTime @map("option_date") @db.Date
  startTime  DateTime @map("start_time") @db.Time
  endTime    DateTime @map("end_time") @db.Time
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants EventDateOptionParticipant[]

  @@map("event_date_options")
}

model EventDateOptionParticipant {
  optionId String @map("option_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
  option   EventDateOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([optionId, userId])
  @@map("event_date_option_participants")
}

model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  eventId     String           @map("event_id") @db.Uuid
  organizerId String           @map("organizer_id") @db.Uuid
  inviteeId   String           @map("invitee_id") @db.Uuid
  status      InvitationStatus @default(pending)
  message     String?
  invitedAt   DateTime         @default(now()) @map("invited_at")
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer   User             @relation("InvitationOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  invitee     User             @relation("InvitationInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Category {
  id          String @id
  name        String
  emoji       String?
  description String?
  color       String?
  users       UserCategory[]

  @@map("categories")
}

model Allergen {
  id    String @id
  name  String
  emoji String?
  users UserAllergen[]

  @@map("allergens")
}

model UserCategory {
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("user_categories")
}

model UserAllergen {
  userId     String   @map("user_id") @db.Uuid
  allergenId String   @map("allergen_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergen   Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@id([userId, allergenId])
  @@map("user_allergens")
}

model Relationship {
  userId       String             @map("user_id") @db.Uuid
  targetUserId String             @map("target_user_id") @db.Uuid
  status       RelationshipStatus @default(normal)
  createdAt    DateTime           @default(now()) @map("created_at")
  user         User               @relation("RelationshipUser", fields: [userId], references: [id], onDelete: Cascade)
  targetUser   User               @relation("RelationshipTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@id([userId, targetUserId])
  @@map("relationships")
}
